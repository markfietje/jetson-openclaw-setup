#!/bin/bash
# Post-installation script for signal-gateway
# This script runs after the package is installed

set -e

# Package information
PACKAGE_NAME="signal-gateway"
SERVICE_NAME="signal-gateway"
BINARY_PATH="/usr/local/bin/signal-gateway"
WRAPPER_PATH="/usr/local/bin/signal-gateway-wrapper.sh"
SERVICE_PATH="/etc/systemd/system/${SERVICE_NAME}.service"
CONFIG_DIR="/etc/signal-gateway"
DATA_DIR="/var/lib/signal-gateway"

# Colors for output (if terminal supports it)
if [ -t 1 ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    NC='\033[0m'
else
    RED=''
    GREEN=''
    YELLOW=''
    BLUE=''
    NC=''
fi

log_info() {
    echo -e "${GREEN}[INFO]${NC} $*"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $*"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $*"
}

log_note() {
    echo -e "${BLUE}[NOTE]${NC} $*"
}

# Create signal-gateway user if it doesn't exist
if ! id -u signal-gateway &>/dev/null; then
    log_info "Creating signal-gateway system user..."
    useradd --system --no-create-home --shell /bin/false signal-gateway || {
        log_warn "Could not create signal-gateway user (may already exist)"
    }
fi

# Create necessary directories
log_info "Creating directories..."
mkdir -p "${CONFIG_DIR}"
mkdir -p "${DATA_DIR}"
mkdir -p "${DATA_DIR}/signal-data"
mkdir -p "${DATA_DIR}/logs"

# Set permissions
log_info "Setting permissions..."
chown -R signal-gateway:signal-gateway "${DATA_DIR}"
chmod 750 "${DATA_DIR}"
chmod 750 "${DATA_DIR}/signal-data"
chmod 755 "${CONFIG_DIR}"

# Make binary executable
if [ -f "${BINARY_PATH}" ]; then
    chmod +x "${BINARY_PATH}"
    log_info "Binary permissions set"
else
    log_warn "Binary not found at ${BINARY_PATH}"
fi

# Make wrapper script executable
if [ -f "${WRAPPER_PATH}" ]; then
    chmod +x "${WRAPPER_PATH}"
    log_info "Wrapper script permissions set"
fi

# Install systemd service if it exists in the package
if [ -f "${SERVICE_PATH}" ]; then
    log_info "Installing systemd service..."

    # Reload systemd daemon
    systemctl daemon-reload || {
        log_warn "Could not reload systemd daemon"
    }

    # Enable the service
    systemctl enable ${SERVICE_NAME} || {
        log_warn "Could not enable ${SERVICE_NAME} service"
    }

    log_info "Systemd service installed and enabled"
else
    log_warn "Systemd service file not found at ${SERVICE_PATH}"
fi

# Create default config if it doesn't exist
CONFIG_FILE="${CONFIG_DIR}/config.toml"
if [ ! -f "${CONFIG_FILE}" ]; then
    log_info "Creating default configuration..."
    cat > "${CONFIG_FILE}" << 'EOF'
# Signal Gateway Configuration
# Generated by post-install script

[server]
host = "127.0.0.1"
port = 8080

[signal]
# Path to Signal data directory
data_dir = "/var/lib/signal-gateway/signal-data"

# Phone number (required for first-time setup)
# You must set this before starting the service
# phone_number = "+1234567890"

[brain_server]
# Brain Server connection settings
url = "http://127.0.0.1:8765"
timeout_seconds = 30

[logging]
level = "info"
path = "/var/lib/signal-gateway/logs"

[rate_limiting]
# Rate limiting for message sending
enabled = true
max_messages_per_minute = 10
EOF
    chown signal-gateway:signal-gateway "${CONFIG_FILE}"
    chmod 640 "${CONFIG_FILE}"
    log_info "Default configuration created at ${CONFIG_FILE}"

    log_warn ""
    log_warn "═════════════════════════════════════════════════════"
    log_warn "  IMPORTANT: Configuration Required!"
    log_warn "═════════════════════════════════════════════════════"
    log_warn ""
    log_warn "You must configure your Signal phone number before"
    log_warn "starting the service. Edit the config file:"
    log_warn ""
    log_warn "  sudo nano ${CONFIG_FILE}"
    log_warn ""
    log_warn "Set the 'phone_number' field with your Signal number"
    log_warn "in E.164 format (e.g., +1234567890)"
    log_warn ""
fi

# Check if Signal is already linked
SIGNAL_DATA="${DATA_DIR}/signal-data"
if [ ! -d "${SIGNAL_DATA}" ] || [ -z "$(ls -A ${SIGNAL_DATA} 2>/dev/null)" ]; then
    log_note ""
    log_note "═════════════════════════════════════════════════════"
    log_note "  Signal Linking Required"
    log_note "═════════════════════════════════════════════════════"
    log_note ""
    log_note "This appears to be a fresh installation."
    log_note "You will need to link Signal on first start."
    log_note ""
    log_note "Steps:"
    log_note "  1. Start the service: sudo systemctl start ${SERVICE_NAME}"
    log_note "  2. Check logs: sudo journalctl -u ${SERVICE_NAME} -f"
    log_note "  3. Scan the QR code with your Signal app"
    log_note "     (Settings → Linked Devices → Link New Device)"
    log_note ""
fi

# Check if service should be started
# Don't start if this is an upgrade and the service is already running
if [ "$1" = "configure" ]; then
    if [ -z "$2" ]; then
        # First installation - ask if user wants to start
        log_info "First-time installation detected"
        if [ -t 0 ]; then
            # Interactive mode
            echo ""
            read -p "Would you like to start ${SERVICE_NAME} now? (y/N) " -n 1 -r
            echo
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                systemctl start ${SERVICE_NAME} || {
                    log_warn "Could not start ${SERVICE_NAME}"
                }
            else
                log_info "Run 'sudo systemctl start ${SERVICE_NAME}' to start the service"
            fi
        else
            # Non-interactive mode - don't auto-start
            log_info "Run 'sudo systemctl start ${SERVICE_NAME}' to start the service"
        fi
    else
        # Upgrade - restart if service was running
        if systemctl is-active --quiet ${SERVICE_NAME}; then
            log_info "Restarting ${SERVICE_NAME} (service was running during upgrade)..."
            systemctl restart ${SERVICE_NAME} || {
                log_warn "Could not restart ${SERVICE_NAME}"
            }
        else
            log_info "Service ${SERVICE_NAME} was not running, not starting"
        fi
    fi
fi

# Summary
echo ""
log_info "═══════════════════════════════════════════════════════"
log_info "  Signal Gateway Installation Complete!"
log_info "═══════════════════════════════════════════════════════"
echo ""
log_info "Binary:     ${BINARY_PATH}"
log_info "Config:     ${CONFIG_FILE}"
log_info "Data:       ${DATA_DIR}/signal-data/"
log_info "Logs:       ${DATA_DIR}/logs/"
echo ""
log_info "Commands:"
echo "  Start:   sudo systemctl start ${SERVICE_NAME}"
echo "  Stop:    sudo systemctl stop ${SERVICE_NAME}"
echo "  Status:  sudo systemctl status ${SERVICE_NAME}"
echo "  Logs:    sudo journalctl -u ${SERVICE_NAME} -f"
echo ""
log_note "API Endpoints:"
echo "  Health:  http://localhost:8080/v1/health"
echo "  Status:  http://localhost:8080/v1/status"
echo "  Send:    POST http://localhost:8080/v1/send"
echo ""

exit 0
